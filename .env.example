# Database
WIKIMOD_DATABASE_URL=sqlite+aiosqlite:///./wikimod.db

# For PostgreSQL (production/Docker):
# WIKIMOD_DATABASE_URL=postgresql+asyncpg://wikimod:wikimod@localhost:5432/wikimod

# Model paths (defaults are fine for local development)
# WIKIMOD_MODEL_PATH=backend/app/ml/model.pkl
# WIKIMOD_VECTORIZER_PATH=backend/app/ml/vectorizer.pkl

# Rate limiting
# WIKIMOD_RATE_LIMIT=5/minute
